# Application
APP_NAME=Kompak Accounting
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DB_PRIMARY_URL=postgresql+asyncpg://kompak:kompak@localhost:5432/kompak_accounting
DB_REPLICA_URL=postgresql+asyncpg://kompak:kompak@localhost:5432/kompak_accounting
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER=redis://localhost:6379/1
REDIS_CELERY_BACKEND=redis://localhost:6379/2

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=https://accounting.kompakapps.com,http://localhost:3000

# Object Storage (Linode Object Storage / S3)
S3_ENDPOINT=https://us-east-1.linodeobjects.com
S3_BUCKET=kompak-accounting
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Rate Limiting (per minute)
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=600
RATE_LIMIT_ENTERPRISE=6000
